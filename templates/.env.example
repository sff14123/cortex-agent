# ===================================================
# Cortex Agent 환경변수 설정 파일
# 이 파일을 복사하여 .env로 저장 후 값을 입력하세요.
# cp .env.example .env
# ===================================================

# 1. GitLab 설정
GITLAB_URL=""
GITLAB_TOKEN=""
GITLAB_PROJECT_ID=""

# 2. Hugging Face 인증 (선택사항, 권장)
# 임베딩 모델(BGE-M3 등)의 빠른 다운로드 및 권한 이슈 방지를 위해 설정합니다.
# 발급: https://huggingface.co/settings/tokens
HF_TOKEN=""

# 3. 외부 임베딩 API 키 (선택사항)
# GPU/CPU가 충분한 경우 기본적으로 로컬 모델(BGE-M3)을 사용합니다.
# 하드웨어 사양이 부족한 경우 외부 API(OpenAI 등)를 사용할 수 있습니다.
CORTEX_EMBEDDING_API_KEY=""