# Python & Runtime
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
uv.lock
.env

# Dynamic Data (Protected)
data/
history/
!history/inbox.md
state/
memo.md

# Project-Specific Assets (Isolated)
rules/*/
!rules/core/
docs/

# Metadata
PROGRESS.md

# User-local overrides (per-user, not shared)
settings.local.yaml

# Allow .gitkeep in all ignored directories
!**/.gitkeep